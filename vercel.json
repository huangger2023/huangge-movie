{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.hgsdy.cn"
        }
      ],
      "destination": "https://hgsdy.cn/$1",
      "permanent": true
    },
    {
      "source": "/wx",
      "destination": "/pay/wechat",
      "permanent": false
    },
    {
      "source": "/zfb",
      "destination": "/pay/alipay",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
